/* Auto-generated by wallust — DO NOT EDIT */

@define-color background               {{background}};
@define-color surface                  {{color0}};
@define-color surface_container        {{color0}};
@define-color surface_container_high   {{color8}};
@define-color surface_container_highest {{color8}};
@define-color surface_container_low    {{color0}};
@define-color surface_bright           {{color7}};

@define-color on_surface               {{foreground}};
@define-color on_surface_variant       {{color7}};
@define-color inverse_surface          {{foreground}};

@define-color primary                  {{color1}};
@define-color primary_fixed            {{color1}};
@define-color primary_fixed_dim        {{color9}};
@define-color on_primary               {{background}};

@define-color secondary                {{color4}};
@define-color on_secondary             {{background}};
@define-color secondary_container      {{color8}};
@define-color on_secondary_container   {{foreground}};
@define-color on_secondary_fixed_variant {{color7}};

@define-color tertiary                 {{color6}};
@define-color on_tertiary              {{background}};

@define-color error                    {{color9}};
@define-color on_error                 {{foreground}};

@define-color outline                  {{color8}};
@define-color outline_variant          {{color8}};

* {
    border: none;
    border-radius: 0;
    font-family: "JetBrainsMono Nerd Font", "JetBrains Mono", sans-serif;
    font-weight: bold;
    font-size: 12px;
    min-height: 0;
    padding: 0;
    margin: 0;
}

window#waybar {
    background: alpha({{background}}, 0.85);
    color: @on_surface;
    border-bottom: 1px solid alpha(@outline, 0.3);
}

tooltip {
    background: @background;
    border: 1px solid @outline;
    border-radius: 0;
    color: @on_surface;
}
tooltip label {
    padding: 4px 8px;
    color: @on_surface;
}

.modules-left {
    margin-left: 8px;
}

.modules-right {
    margin-right: 8px;
}

#clock {
    padding: 0 16px;
    margin: 0 4px;
    color: @on_surface;
}

#custom-media {
    padding: 0 10px;
    margin: 0 4px;
    color: @on_surface_variant;
}

#custom-media.playing {
    color: @primary;
}

#custom-media.paused {
    color: @on_surface_variant;
}

#custom-media-prev,
#custom-media-next {
    padding: 0 6px;
    color: @on_surface_variant;
}

#custom-media-prev.playing,
#custom-media-next.playing {
    color: @primary;
}

#custom-media-prev.paused,
#custom-media-next.paused {
    color: @on_surface_variant;
}

#network {
    padding: 0 10px;
    margin: 0 2px;
    color: @on_surface_variant;
}

#network label.disconnected {
    opacity: 0.35;
}

#network label.linked,
#network label.ethernet {
    color: @tertiary;
}

#network:hover {
    background: alpha(@primary, 0.15);
}

#bluetooth {
    padding: 0 10px;
    margin: 0 3px;
    color: @on_surface_variant;
}

#bluetooth label.disabled,
#bluetooth label.off {
    opacity: 0.5;
}

#bluetooth label.on {
    opacity: 0.35;
}

#bluetooth:hover {
    background: alpha(@primary, 0.15);
}

#pulseaudio {
    padding: 0 10px;
    margin: 0 3px;
    color: @on_surface_variant;
}

#pulseaudio.muted {
    color: @outline;
}

#pulseaudio:hover {
    background: alpha(@primary, 0.15);
}

#cpu {
    padding: 0 10px;
    margin: 0 3px;
    color: @on_surface_variant;
}

#cpu:hover {
    background: alpha(@primary, 0.15);
}

#memory {
    padding: 0 10px;
    margin: 0 3px;
    color: @on_surface_variant;
}

#memory:hover {
    background: alpha(@primary, 0.15);
}

#custom-power-profiles {
    padding: 0 10px;
    margin: 0 3px;
    color: @on_surface_variant;
}

#custom-power-profiles:hover {
    background: alpha(@primary, 0.15);
}

#custom-power {
    padding: 0 10px;
    margin: 0 3px;
    color: @on_surface_variant;
    font-size: 13px;
}

#custom-power:hover {
    background: alpha(@error, 0.2);
    color: @error;
}

#tray {
    padding: 0 8px;
    margin: 0 3px;
}

#tray > .passive {
    -gtk-icon-effect: dim;
}

#tray > .needs-attention {
    -gtk-icon-effect: highlight;
    background-color: alpha(@error, 0.1);
}

#custom-workspaces {
    margin: 0;
    padding: 0 4px 0 12px;
    letter-spacing: 2px;
    color: @on_surface;
    font-weight: 800;
}

#custom-runcat {
    margin: 0;
    padding: 0 2px 0 4px;
    font-family: "runcat", "JetBrainsMono Nerd Font", monospace;
    font-size: 18px;
    letter-spacing: 0;
    color: @on_surface_variant;
}

#custom-runcat.low {
    color: @on_surface;
}

#custom-runcat.medium {
    color: @secondary;
}

#custom-runcat.high {
    color: @error;
}

#custom-recording {
    padding: 0 10px;
    margin: 0 3px;
}

#custom-recording.recording {
    color: @error;
}

#custom-recording.idle {
    color: transparent;
}

#custom-brightness {
    padding: 0 6px;
    color: @on_surface_variant;
}

#custom-notification {
    padding: 0 6px;
    color: @on_surface_variant;
}

#custom-notification.has {
    opacity: 1;
}

#custom-notification.dnd {
    color: @error;
}

#custom-notification.none {
    opacity: 0.35;
}


