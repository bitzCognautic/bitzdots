  --accent: {{color1}};
  --border-color: rgba({{color9 | rgb}}, 0.28);
  --border-radius: 0;
}

notificationwindow {
  background: transparent;
}

.control-center {
  background: var(--cc-bg);
  color: var(--text-main);
  border-radius: var(--border-radius);
  border: 1px solid var(--border-color);
  box-shadow: 0 4px 20px rgba(0,0,0,0.7);
  padding: 4px;
}

.widget {
  margin: 3px;
  padding: 5px;
  border-radius: var(--border-radius);
}

.widget-title > label {
  color: var(--accent);
  font-weight: bold;
  font-size: 18px;
}

.widget-title > button {
  background: rgba({{color1 | rgb}}, 0.22);
  border: 1px solid rgba({{color9 | rgb}}, 0.35);
  border-radius: 0;
  padding: 4px 12px;
}

.widget-title > button:hover {
  background: rgba({{color9 | rgb}}, 0.65);
  border-color: var(--accent);
}

.widget-mpris {
  background: rgba(0,0,0,0.28);
  border-radius: var(--border-radius);
  overflow: hidden;
}

.widget-mpris-title {
  color: var(--accent);
  font-weight: bold;
  font-size: 16px;
}

.widget-mpris-subtitle {
  color: var(--text-dim);
  font-size: 13px;
}

.widget-mpris-album-art {
  border-radius: 0;
}

.widget-volume,
.widget-backlight {
  background: transparent;
}

.widget-volume label,
