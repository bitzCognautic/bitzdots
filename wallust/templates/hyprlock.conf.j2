# Auto-generated by wallust — hyprlock theme

background {
    monitor =
    path = $HOME/.cache/current_wallpaper.png
    blur_passes = 3
    blur_size = 8
}

input-field {
    monitor =
    size = 300, 50
    outline_thickness = 2
    dots_size = 0.33
    dots_spacing = 0.15
    dots_center = true
    rounding = 0
    outer_color = rgb({{color1 | rgb}})
    inner_color = rgb({{color0 | rgb}})
    font_color = rgb({{foreground | rgb}})
    check_color = rgb({{color4 | rgb}})
    fail_color = rgb({{color9 | rgb}})
    capslock_color = rgb({{color3 | rgb}})
    fade_on_empty = true
    placeholder_text = <i>Password...</i>
    hide_input = false
    position = 0, -180
    halign = center
    valign = center
}

label {
    text = cmd[update:1000] echo "$(date '+%I:%M %p')"
    font_size = 72
    font_family = JetBrainsMono Nerd Font
    color = rgb({{foreground | rgb}})
    position = 0, 100
    halign = center
    valign = center
}

label {
    text = cmd[update:3600] echo "$(date '+%A, %d %B %Y')"
    font_size = 24
    font_family = JetBrainsMono Nerd Font
    color = rgb({{color7 | rgb}})
    position = 0, 40
    halign = center
    valign = center
}

