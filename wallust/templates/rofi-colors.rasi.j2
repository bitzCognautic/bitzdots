/* Auto-generated by wallust — DO NOT EDIT */

* {
    bg0:    {{color0}};
    bg1:    {{color8}};
    fg0:    {{foreground}};
    fg1:    {{color7}};
    accent: {{color1}};
    select: {{color8}};
    urgent: {{color9}};

    background-color: transparent;
    text-color:       @fg0;
    font:            "JetBrainsMono Nerd Font Medium 10";
}

window {
    width:            850px;
    border:           2px;
    border-color:     @accent;
    border-radius:    0;
    background-color: @bg0;
}

mainbox {
    children: [ inputbar, listview ];
}

inputbar {
    padding:          12px;
    background-color: @bg1;
    children:         [ prompt, entry ];
}

prompt {
    text-color: @accent;
}

listview {
    columns:      3;
    lines:        2;
    spacing:      20px;
    padding:      20px;
    fixed-height: false;
    flow:         horizontal;
}

element {
    orientation:      vertical;
    padding:          15px;
    border-radius:    0;
    spacing:          10px;
}

element selected {
    background-color: @select;
    border:           3px;
    border-color:     @accent;
}

element selected text {
    text-color:       @accent;
}

element-icon {
    size:             180px;
    horizontal-align: 0.5;
}

element-text {
    horizontal-align: 0.5;
    text-color:       @fg1;
}
