/* Auto-generated by wallust — app launcher theme */

* {
    bg0:    {{color0}};
    bg1:    {{color8}};
    fg0:    {{foreground}};
    fg1:    {{color7}};
    accent: {{color1}};
    select: {{color8}};

    background-color: transparent;
    text-color:       @fg0;
    font:            "JetBrainsMono Nerd Font Medium 10";
}

window {
    width:            600px;
    border:           3px;
    border-color:     @accent;
    border-radius:    0;
    background-color: @bg0;
}

mainbox {
    children: [ inputbar, listview ];
}

inputbar {
    padding:          14px 18px 10px;
    background-color: @bg1;
    children:         [ prompt, entry ];
}

prompt {
    font:            "JetBrainsMono Nerd Font Bold 12";
    text-color:      @accent;
}

entry {
    placeholder:     "Search apps...";
    placeholder-color: @fg1;
    cursor:          text;
}

listview {
    columns:      2;
    lines:        6;
    spacing:      4px;
    padding:      8px;
    fixed-height: false;
    flow:         horizontal;
}

element {
    padding:          8px 12px;
    spacing:          10px;
    border-radius:    0;
}

element normal {
    background-color: transparent;
    border:           1px;
    border-color:     @accent;
    text-color:       @fg0;
}
element selected {

    background-color: @select;
    border:           3px;
    border-color:     @accent;
}

element selected text {
    text-color:       @accent;
}

element-icon {
    size:             24px;
    vertical-align:   0.5;
}

element-text {
    vertical-align:   0.5;
}
